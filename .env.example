# Create one webhook in each server under Server Settings -> Integrations -> Webhooks.
DISCORD_TEST_WEBHOOK_URL=https://discord.com/api/webhooks/your-test-webhook-id/your-test-webhook-token
DISCORD_PRODUCTION_WEBHOOK_URL=https://discord.com/api/webhooks/your-production-webhook-id/your-production-webhook-token

# Optional message customization
WEBHOOK_USERNAME=Question of the Day
QUESTION_MESSAGE_PREFIX=**Question of the day:**
POLL_MESSAGE_PREFIX=**Poll of the day:**
